                                                </svg>
                                            </a>
                                            <a href="<?= buildPaginationUrl($pagination['total_pages'], $perPage ?? 10, $searchTerm ?? '', $academicYearId ?? '', $dateFrom ?? '', $dateTo ?? '', $enableDateFilter ?? false, $reportType ?? '', 'payments') ?>" 
