                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paid Amount</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                `;
                
                let totalExpected = 0;
                let totalPaid = 0;
                let totalBalance = 0;
                
                data.student.fees.forEach(fee => {
                    totalExpected += parseFloat(fee.expected_amount) || 0;
                    totalPaid += parseFloat(fee.paid_amount) || 0;
                    totalBalance += parseFloat(fee.balance) || 0;
                    
                    html += `
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${fee.fee_name}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">₵${parseFloat(fee.expected_amount || 0).toFixed(2)}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">₵${parseFloat(fee.paid_amount || 0).toFixed(2)}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm ${fee.balance > 0 ? 'text-red-600 font-bold' : 'text-green-600'}">
                                ₵${parseFloat(fee.balance || 0).toFixed(2)}
                            </td>
                        </tr>
                    `;
                });
                
                html += `
                            </tbody>
                            <tfoot class="bg-gray-50">
                                <tr>
                                    <td class="px-6 py-3 text-sm font-medium text-gray-900">Total</td>
                                    <td class="px-6 py-3 text-sm font-bold text-gray-900">₵${totalExpected.toFixed(2)}</td>
                                    <td class="px-6 py-3 text-sm font-bold text-gray-900">₵${totalPaid.toFixed(2)}</td>
                                    <td class="px-6 py-3 text-sm font-bold ${totalBalance > 0 ? 'text-red-600' : 'text-green-600'}">₵${totalBalance.toFixed(2)}</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                `;
                
                content.innerHTML = html;
            } else {
                content.innerHTML = '<p class="text-red-500">Failed to load student details.</p>';
            }
        })
        .catch(error => {
            content.innerHTML = '<p class="text-red-500">Error loading student details.</p>';
        });
    }
});

