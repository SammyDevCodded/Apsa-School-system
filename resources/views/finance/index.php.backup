// Print summary only function
function printSummaryOnlyFunction() {
    // Get the report summary table
    const reportTable = document.querySelector('.bg-white.shadow.overflow-hidden.sm\\:rounded-lg.mb-6 table');
    const reportTitle = document.querySelector('.bg-white.shadow.overflow-hidden.sm\\:rounded-lg.mb-6 h2').textContent;
    const reportTotal = document.querySelector('.bg-white.shadow.overflow-hidden.sm\\:rounded-lg.mb-6 .text-lg.font-bold.text-indigo-600').textContent;
    if (!reportTable) {
        alert('No report summary to print');
        return;
    }
    // Clone the table to avoid modifying the original
    const clonedTable = reportTable.cloneNode(true);
    // Create print window
    const printWindow = window.open('', '_blank');
    printWindow.document.write(`
                    </tfoot>
                </table>
                <script>
                    window.onload = function() {
                        window.print();
                    }
                <\/script>
            </body>
        </html>
    `);
    printWindow.document.close();
});
